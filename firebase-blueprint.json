{
  "entities": {
    "Item": {
      "title": "Lost or Found Item",
      "description": "A report of a lost or found item.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["lost", "found"],
          "description": "Whether the item was lost or found."
        },
        "displayId": {
          "type": "string",
          "description": "Unique 6-digit ID for the report."
        },
        "title": {
          "type": "string",
          "description": "Brief title of the item."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the item."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL of the item image."
        },
        "road": {
          "type": "string",
          "description": "Road name or number."
        },
        "houseNo": {
          "type": "string",
          "description": "House or building number."
        },
        "village": {
          "type": "string",
          "description": "Village or area name."
        },
        "postOffice": {
          "type": "string",
          "description": "Post office name."
        },
        "country": {
          "type": "string",
          "description": "Country name (for international)."
        },
        "location": {
          "type": "string",
          "description": "General location or city."
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "When the item was lost or found."
        },
        "category": {
          "type": "string",
          "description": "Category of the item (e.g., Human, Phone, Laptop)."
        },
        "contactInfo": {
          "type": "string",
          "description": "How to contact the poster."
        },
        "mobile": {
          "type": "string",
          "description": "Mobile number for the poster."
        },
        "posterId": {
          "type": "string",
          "description": "UID of the user who posted the item."
        },
        "posterEmail": {
          "type": "string",
          "description": "Email of the user who posted the item."
        },
        "status": {
          "type": "string",
          "enum": ["active", "resolved"],
          "description": "Current status of the report."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the report was created."
        }
      },
      "required": ["type", "displayId", "title", "description", "location", "date", "posterId", "status", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "description": "User's email address."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "User's role in the application."
        },
        "displayName": {
          "type": "string",
          "description": "User's display name."
        }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/items/{itemId}": {
      "schema": "Item",
      "description": "Collection of lost and found items."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles and roles."
    }
  }
}
